# Copy to backend/.env and fill in values
# cp backend/.env.example backend/.env

# JWT - REQUIRED in production. Use a long random string.
JWT_SECRET_KEY=krishisahyog-dev-secret-change-in-production

# Database - SQLite by default
# DATABASE_URL=sqlite:///./krishisahyog.db
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@host/db

# CORS - comma-separated frontend origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM - at least one required for chatbot
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Alternative: Gemini
# GEMINI_API_KEY=
